# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local environment and logs
.env
.env.*
*.log

# Runtime artifacts generated by pipeline
data/raw/*
data/processed/*
models/baseline/*
models/main/*
reports/daily/*
reports/daily/assets/*
reports/backtest/*
reports/monitoring/*

# Keep folder scaffolding in Git
!data/raw/.gitkeep
!data/processed/.gitkeep
!models/baseline/.gitkeep
!models/main/.gitkeep
!reports/daily/.gitkeep
!reports/daily/assets/
!reports/daily/assets/.gitkeep
!reports/backtest/.gitkeep
!reports/monitoring/.gitkeep
